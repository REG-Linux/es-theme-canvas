{
  "defaultTransition": "instant",
  "formatVersion": 7.0,
  "nodes": [
    {
      "type": "include",
      "path": "${themePath}/_inc/variables/variables.json"
    },
    {
      "type": "include",
      "path": "${themePath}/_inc/fonts/fonts.json"
    },
    {
      "type": "include",
      "path": "${themePath}/_inc/colors.json"
    },
    {
      "type": "subset",
      "name": "aspect-ratio",
      "displayName": "Aspect Ratio",
      "nodes": [
        {
          "type": "include",
          "name": "1-1-auto",
          "displayName": "Automatic",
          "filters": {
            "if": "{screen.ratio} == '1/1'"
          }
        },
        {
          "type": "include",
          "name": "16-9-auto",
          "displayName": "Automatic",
          "filters": {
            "if": "{screen.ratio} == '16/9'"
          }
        },
        {
          "type": "include",
          "name": "16-10-auto",
          "displayName": "Automatic",
          "filters": {
            "if": "{screen.ratio} == '16/10'"
          }
        },
        {
          "type": "include",
          "name": "4-3-auto",
          "displayName": "Automatic",
          "filters": {
            "if": "{screen.ratio} == '4/3'"
          }
        },
        {
          "type": "include",
          "name": "16-9",
          "displayName": "16:9"
        },
        {
          "type": "include",
          "name": "16-10",
          "displayName": "16:10"
        },
        {
          "type": "include",
          "name": "4-3",
          "displayName": "4:3"
        },
        {
          "type": "include",
          "name": "1-1",
          "displayName": "1:1"
        }
